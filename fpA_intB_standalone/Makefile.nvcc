THIS_DIR := $(patsubst %/,%,$(dir $(abspath $(lastword $(MAKEFILE_LIST)))))

NVCC ?= nvcc
_DEFAULT_CXX := $(shell command -v g++-12 2>/dev/null || command -v g++-11 2>/dev/null || command -v g++ 2>/dev/null || command -v c++ 2>/dev/null)
ifeq ($(origin CXX),default)
CXX := $(_DEFAULT_CXX)
endif
CXX ?= c++
HOST_CXX ?= $(CXX)
GPU_ARCH ?= sm_90a
BUILD_DIR ?= $(THIS_DIR)/build_nvcc
TARGET ?= $(BUILD_DIR)/test_fpA_intB_gemm
CUDA_HOME ?= /usr/local/cuda

_CUTLASS_CANDIDATES := \
	$(THIS_DIR)/../../../third_party/cutlass \
	$(THIS_DIR)/../../../thirdparty/cutlass \
	$(THIS_DIR)/../3rdparty/cutlass \
	$(HOME)/TensorRT-LLM/3rdparty/cutlass
CUTLASS_DIR ?= $(firstword $(foreach d,$(_CUTLASS_CANDIDATES),$(if $(wildcard $(d)/include/cutlass/cutlass.h),$(d))))
ifeq ($(strip $(CUTLASS_DIR)),)
CUTLASS_DIR := $(THIS_DIR)/../../../third_party/cutlass
endif

OPT ?= -O3
STD ?= -std=c++17
EXTRA_NVCCFLAGS ?=
EXTRA_CXXFLAGS ?=
LDLIBS ?= -lcudart
NVCC_FORWARD_UNKNOWN ?= 0

CLANG_CUDA_FLAGS ?= -fno-cuda-host-device-constexpr
NVCC_ACCEPTS_CLANG_CUDA_FLAGS = $(shell \
	tmp=$$(mktemp /tmp/fpa_nvcc_probe_XXXXXX.cu); \
	obj=$$tmp.o; \
	printf '__global__ void f(){} int main(){return 0;}\n' > $$tmp; \
	if $(NVCC) $(STD) -arch=$(GPU_ARCH) $(CLANG_CUDA_FLAGS) -c $$tmp -o $$obj >/dev/null 2>&1; then \
		printf 1; \
	else \
		printf 0; \
	fi; \
	rm -f $$tmp $$obj)
CLANG_CUDA_COMPAT ?= $(NVCC_ACCEPTS_CLANG_CUDA_FLAGS)
ifeq ($(CLANG_CUDA_COMPAT),1)
EXTRA_NVCCFLAGS += $(CLANG_CUDA_FLAGS)
endif
ifeq ($(NVCC_FORWARD_UNKNOWN),1)
EXTRA_NVCCFLAGS += -forward-unknown-to-host-compiler
endif

INCLUDE_DIRS := \
	$(THIS_DIR)/cpp/include \
	$(THIS_DIR)/cpp \
	$(THIS_DIR)/cpp/tensorrt_llm \
	$(THIS_DIR)/cpp/tensorrt_llm/cutlass_extensions/include \
	$(CUTLASS_DIR)/include \
	$(CUDA_HOME)/include

DEFS := \
	-DENABLE_BF16=0 \
	-DENABLE_FP8=0 \
	-DENABLE_FP4=0

ifneq (,$(findstring sm_90,$(GPU_ARCH)))
DEFS += -DCOMPILE_HOPPER_TMA_GEMMS=1 -DCUTLASS_ARCH_MMA_SM90_SUPPORTED=1
endif

NVCCFLAGS := $(OPT) $(STD) -DNDEBUG -ccbin=$(HOST_CXX) -arch=$(GPU_ARCH) --expt-relaxed-constexpr $(EXTRA_NVCCFLAGS)
CXXFLAGS := $(OPT) $(STD) -DNDEBUG $(EXTRA_CXXFLAGS)
INCLUDES := $(addprefix -I,$(INCLUDE_DIRS))

SRC_REL := \
	cpp/tensorrt_llm/kernels/cutlass_kernels/cutlass_heuristic.cpp \
	cpp/tensorrt_llm/kernels/cutlass_kernels/cutlass_preprocessors.cpp \
	cpp/tensorrt_llm/kernels/cutlass_kernels/fpA_intB_gemm/fp16_int4_gemm_fg_scalebias.cu \
	cpp/tensorrt_llm/kernels/cutlass_kernels/fpA_intB_gemm/launchers/fpA_intB_gemm_sm80_wrappers.cu \
	cpp/tensorrt_llm/kernels/weightOnlyBatchedGemv/kernelDispatcherFp16Int4GroupwiseColumnMajorInterleavedTrue.cu \
	test/test_fpA_intB_gemm.cu

OBJECTS := $(addprefix $(BUILD_DIR)/obj/,$(addsuffix .o,$(SRC_REL)))

.PHONY: all clean check-cutlass print

all: $(TARGET)

check-cutlass:
	@test -f "$(CUTLASS_DIR)/include/cutlass/cutlass.h" || { \
		echo "CUTLASS not found at CUTLASS_DIR=$(CUTLASS_DIR)"; \
		echo "Pass CUTLASS_DIR=/path/to/cutlass"; \
		exit 1; \
	}

$(TARGET): check-cutlass $(OBJECTS)
	@mkdir -p "$(BUILD_DIR)"
	$(NVCC) $(NVCCFLAGS) $(OBJECTS) -o "$@" $(LDLIBS)

$(BUILD_DIR)/obj/%.cu.o: $(THIS_DIR)/%.cu
	@mkdir -p "$(@D)"
	$(NVCC) $(NVCCFLAGS) $(DEFS) $(INCLUDES) -c "$<" -o "$@"

$(BUILD_DIR)/obj/%.cpp.o: $(THIS_DIR)/%.cpp
	@mkdir -p "$(@D)"
	$(CXX) $(CXXFLAGS) $(DEFS) $(INCLUDES) -c "$<" -o "$@"

print:
	@printf 'NVCC=%s\n' '$(NVCC)'
	@printf 'CXX=%s\n' '$(CXX)'
	@printf 'HOST_CXX=%s\n' '$(HOST_CXX)'
	@printf 'GPU_ARCH=%s\n' '$(GPU_ARCH)'
	@printf 'CUTLASS_DIR=%s\n' '$(CUTLASS_DIR)'
	@printf 'CUDA_HOME=%s\n' '$(CUDA_HOME)'
	@printf 'BUILD_DIR=%s\n' '$(BUILD_DIR)'
	@printf 'TARGET=%s\n' '$(TARGET)'
	@printf 'CLANG_CUDA_COMPAT=%s\n' '$(CLANG_CUDA_COMPAT)'
	@printf 'NVCC_FORWARD_UNKNOWN=%s\n' '$(NVCC_FORWARD_UNKNOWN)'
	@printf 'NVCCFLAGS=%s\n' '$(NVCCFLAGS)'
	@printf 'CXXFLAGS=%s\n' '$(CXXFLAGS)'
	@printf 'DEFS=%s\n' '$(DEFS)'

clean:
	$(RM) -r "$(BUILD_DIR)"
